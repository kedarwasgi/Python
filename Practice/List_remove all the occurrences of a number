#remove all the occurrences of a user entered number from the list

lst = [3,3,3,3,3,2,4,3,5,6,5,6,7,9,8,6,0,15]

#target value to be removed from list
n = 3

#Solution1 : in-place removal
for i in range(0,lst.count(n)):
    lst.remove(n)

#Solution2 : in-place removal
while n in lst:
    lst.remove(n)

#Solution3 : new list
new_lst = []
for i in lst:
    if i==n:
        continue
    else:
        new_lst.append(i)

print(new_lst)
